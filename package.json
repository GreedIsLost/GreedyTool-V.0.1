{
  "name": "greedytool",
  "version": "2.1.0",
  "description": "Steam Manifest & Lua Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "NODE_ENV=development electron .",
    "postinstall": "node core/setup-sam.js",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.greed.steam-tool",
    "productName": "Greed",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      { "from": "sam", "to": "sam", "filter": ["**/*", "!sam.zip"] }
    ],
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "core/**/*",
      "renderer/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "archiver": "^7.0.0",
    "axios": "^1.7.0",
    "fs-extra": "^11.0.0",
    "protobufjs": "^7.6.4"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8"
  }
}
